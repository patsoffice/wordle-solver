# Load the Nix dev shell (shell.nix) for a reproducible Rust toolchain plus the
# native deps reqwest links against (openssl, pkg-config). Guarded with
# `has nix` so direnv stays inert on machines without Nix, where the crate
# builds fine with a system rustc + pkg-config + openssl.
if has nix; then
  use nix
else
  log_status "nix not found; skipping dev shell (use system rustc to build)"
fi
